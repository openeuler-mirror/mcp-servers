{
  "mcpServers": {
    "cvekit_mcp": {
      "command": "uv",
      "env": {
        "LANG": "en_US.UTF-8"
      },
      "args": [
        "--directory",
        "/opt/mcp-servers/servers/cvekit_mcp/src",
        "run",
        "server.py",
        "--llm-provider", "deepseek",
        "--gitee-token", "",
        "--openai-key", ""
      ],
      "disabled": false,
      "alwaysAllow": [],
      "description": "Gitee代码仓CVE补丁处理服务",
      "timeout": 600
    }
  }
}
