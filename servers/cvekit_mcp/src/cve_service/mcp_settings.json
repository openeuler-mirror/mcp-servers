{
  "mcpServers": {
    "cvekit_mcp": {
      "command": ".venv/bin/python",
      "env": {
        "LANG": "en_CN.UTF-8",
        "PYTHONPATH": "path/to/cvekit_mcp/src"
      },
      "args": [
        "path/to/cvekit_mcp/src/server.py",
        "--gitee-token", 
        "xxx",
        "--llm-provider",
        "xxx",
        "--openai-key",
        "xxx"
      ],
      "disabled": false,
      "alwaysAllow": [],
      "description": "Gitee代码仓CVE补丁处理服务",
      "timeout": 1200
    }
  }
}