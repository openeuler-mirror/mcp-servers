{
  "mcpServers": {
    "k8s_cluster_manager_mcp": {
      "command": "uv",
      "args": [
        "--directory",
        "/opt/mcp-servers/servers/k8s_cluster_manager_mcp/src",
        "run",
        "server.py"
      ],
      "disabled": false,
      "alwaysAllow": [
        "cluster_status",
        "get_nodes",
        "get_pods",
        "get_services",
        "apply_manifest",
        "delete_resource",
        "get_logs",
        "scale_deployment",
        "k3s_install",
        "k3s_remove"
      ]
    }
  }
}